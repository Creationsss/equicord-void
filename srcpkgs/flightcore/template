# Template file for 'flightcore'
pkgname=flightcore
version=3.2.0
revision=1
archs="x86_64"
create_wrksrc=yes
depends="gtk+3 libwebkit2gtk41 libsoup3 gst-plugins-base1 libgcrypt"
short_desc="Installer/Updater/Launcher for Northstar"
maintainer="creations <creations@creations.works>"
license="MIT"
homepage="https://github.com/R2NorthstarTools/FlightCore"
distfiles="https://github.com/R2NorthstarTools/FlightCore/releases/download/v${version}/FlightCore_${version}_amd64.AppImage"
checksum=2b5ef86a6fb99dc4e262ab6abcf452b96b57b85ab19ee2c2bda4ee6752c8c13b
nostrip=yes
allow_unknown_shlibs=yes

do_extract() {
	local _appimage="${XBPS_SRCDISTDIR}/${pkgname}-${version}/FlightCore_${version}_amd64.AppImage"
	chmod +x "$_appimage"
	"$_appimage" --appimage-extract
	cp -a squashfs-root/. .
	rm -rf squashfs-root
}

do_install() {
	vmkdir usr/lib/flightcore
	vcopy usr/bin/flightcore usr/lib/flightcore
	vcopy "usr/lib/*" usr/lib/flightcore
	chmod 755 ${DESTDIR}/usr/lib/flightcore/flightcore
	vbin ${FILESDIR}/flightcore.sh flightcore
	vinstall ${FILESDIR}/flightcore.desktop 644 usr/share/applications
	vinstall flightcore.png 644 usr/share/pixmaps
	vlicense ${FILESDIR}/LICENSE
}

# Template file for 'grabit'
pkgname=grabit
version=1.1.7
revision=1
depends="bash curl jq xdg-utils libnotify python3"
short_desc="Screenshot, screen recording, and file uploader with OCR support"
maintainer="creations <creations@creations.works>"
license="BSD-3-Clause"
homepage="https://heliopolis.live/creations/grabit"
distfiles="https://heliopolis.live/creations/grabit/-/archive/v${version}/grabit-v${version}.tar.gz"
checksum=7c17502809baf02a38fbd705a9348ef3a0bab46b1f1b8ece2347a208fc6c428d
wrksrc="grabit-v${version}"

do_install() {
	vmkdir usr/share/grabit/helpers
	vinstall main.sh 755 usr/share/grabit
	for f in helpers/*.sh; do
		vinstall "$f" 644 usr/share/grabit/helpers
	done
	for f in helpers/*.py; do
		vinstall "$f" 755 usr/share/grabit/helpers
	done
	vmkdir usr/bin
	ln -s /usr/share/grabit/main.sh ${DESTDIR}/usr/bin/grabit
	vlicense LICENSE
}
